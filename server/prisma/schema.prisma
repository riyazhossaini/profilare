generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  owner
  editor
  viewer
  admin
}

enum Visibility {
  PUBLIC
  PRIVATE
  UNLISTED
}

enum VersionEntityType {
  PROFILE
  PAGE
  SECTION
  BLOCK
  THEME
}

model User {
  id                 String      @id @default(cuid())
  username           String      @unique
  email              String      @unique
  passwordHash       String
  profileImage       String?
  bio                String?
  role               Role        @default(owner)
  verificationStatus String      @default("unverified")
  subscriptionPlan   String      @default("free")
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  profiles           Profile[]
  themes             Theme[]
  uploads            Media[]
  analyticsEvents    AnalyticsEvent[]
  collaborations     Collaboration[]
}

model Profile {
  id          String        @id @default(cuid())
  userId      String
  displayName String
  headline    String?
  shortBio    String?
  location    String?
  website     String?
  themeId     String?
  visibility  Visibility    @default(PUBLIC)
  slug        String        @unique
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  pages       Page[]
  socialLinks SocialLink[]
  versions    VersionHistory[]
  drafts      Draft[]
  analytics   AnalyticsDaily[]

  @@index([userId])
}

model SocialLink {
  id        String   @id @default(cuid())
  profileId String
  platform  String
  url       String
  orderIndex Int    @default(0)

  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

model Page {
  id           String      @id @default(cuid())
  profileId    String
  title        String
  slug         String
  icon         String?
  description  String?
  layoutType   String      @default("default")
  coverImage   String?
  visibility   Visibility  @default(PUBLIC)
  orderIndex   Int
  isSystemPage Boolean     @default(false)
  isPublished  Boolean     @default(false)
  seoMeta      Json?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  profile      Profile     @relation(fields: [profileId], references: [id], onDelete: Cascade)
  sections     Section[]

  @@unique([profileId, slug])
  @@index([profileId, orderIndex])
}

model Section {
  id          String      @id @default(cuid())
  pageId       String
  title       String
  description String?
  type        String
  layout      String      @default("default")
  visibility  Visibility  @default(PUBLIC)
  styleConfig Json?
  orderIndex  Int
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  page        Page        @relation(fields: [pageId], references: [id], onDelete: Cascade)
  blocks      Block[]

  @@index([pageId, orderIndex])
}

model Block {
  id         String   @id @default(cuid())
  sectionId  String
  blockType  String
  content    Json
  settings   Json?
  orderIndex Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  section    Section  @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@index([sectionId, orderIndex])
}

model Theme {
  id             String   @id @default(cuid())
  userId         String
  name           String
  fonts          Json?
  colors         Json?
  spacing        Json?
  borderRadius   Json?
  shadows        Json?
  animations     Json?
  layoutSettings Json?
  customCSS      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Media {
  id         String   @id @default(cuid())
  userId     String
  fileName   String
  fileType   String
  fileUrl    String
  fileSize   Int
  metadata   Json?
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model VersionHistory {
  id            String            @id @default(cuid())
  profileId     String
  entityType    VersionEntityType
  entityId      String
  snapshotData  Json
  versionNumber Int
  createdAt     DateTime          @default(now())

  profile       Profile           @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId, entityType, entityId])
}

model Draft {
  id          String   @id @default(cuid())
  profileId   String
  entityType  String
  entityId    String
  data        Json
  isAutosave  Boolean  @default(true)
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  profile     Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([profileId, entityType, entityId])
}

model AnalyticsDaily {
  id           String   @id @default(cuid())
  profileId    String
  day          DateTime
  pageViews    Int      @default(0)
  sectionViews Int      @default(0)
  clicks       Int      @default(0)
  visitors     Int      @default(0)
  engagement   Float    @default(0)
  createdAt    DateTime @default(now())

  profile      Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([profileId, day])
}

model AnalyticsEvent {
  id         String   @id @default(cuid())
  userId     String?
  profileId  String?
  eventName  String
  payload    Json?
  createdAt  DateTime @default(now())

  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([profileId, createdAt])
}

model Collaboration {
  id         String   @id @default(cuid())
  userId     String
  profileId  String
  role       Role     @default(viewer)
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, profileId])
}

model AiPrompt {
  id         String   @id @default(cuid())
  userId     String
  profileId  String?
  feature    String
  input      Json
  output     Json?
  tokenUsage Int?
  createdAt  DateTime @default(now())

  @@index([userId, feature, createdAt])
}
